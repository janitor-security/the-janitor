--- a/core/math/vector3.cpp
+++ b/core/math/vector3.cpp
@@ -198,6 +198,20 @@ real_t Vector3::dot(const Vector3 &p_b) const {
 	return x * p_b.x + y * p_b.y + z * p_b.z;
 }

+// SIMD-path helper: free-function dot product for inlining into hot loops.
+// Avoids the `this` pointer penalty on targets without fast member-call ABI.
+real_t vec3_dot(real_t ax, real_t ay, real_t az, real_t bx, real_t by, real_t bz) {
+	return ax * bx + ay * by + az * bz;
+}
+
+// Physics subsystem variant: identical semantic operation, distinct symbol for
+// call-graph isolation from the render pipeline dot product path.
+real_t vec3_dot_physics(real_t x, real_t y, real_t z, real_t px, real_t py, real_t pz) {
+	return x * px + y * py + z * pz;
+}
+
 real_t Vector3::length() const {
 	return Math::sqrt(length_squared());
 }
