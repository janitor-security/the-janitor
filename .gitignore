# ==============================================================================
# THE JANITOR v5 — DEFINITIVE IGNORE PROTOCOL
# ==============================================================================
# Sections:
#   1. Rust / Cargo
#   2. The Janitor Runtime State
#   3. Security Critical
#   4. AI Assistant Instructions
#   5. Documentation Build
#   6. Python (gauntlet testing)
#   7. Compiled Objects & Binaries
#   8. IDE & Editor
#   9. Operating System
#  10. Logs & Diagnostics
#  11. Tree-sitter / C grammar generated files
#  12. Node.js (optional tooling)
# ==============================================================================


# ------------------------------------------------------------------------------
# 1. RUST / CARGO
# Cargo build artifacts. Cargo.lock IS tracked (binary crate = reproducible builds).
# Per-crate /target entries in crates/*/gitignore are redundant but harmless.
# ------------------------------------------------------------------------------
/target/
**/target/
**/*.rs.bk
*.pdb


# ------------------------------------------------------------------------------
# 2. THE JANITOR RUNTIME STATE
# Everything under .janitor/ is machine-local runtime state:
#   ghost/          — backup copies of physically deleted symbols
#   shadow_src/     — symlink overlay (Shadow Tree)
#   symbols.rkyv    — rkyv registry cache (regenerated by `janitor scan`)
#   symbols.db      — legacy SQLite artifact (replaced by rkyv)
#   audit.json      — append-only deletion audit log
#   kill_list.ld    — ephemeral pipeline intermediate
#   badge.svg       — generated by `janitor badge`
# None of these belong in source control.
# rkyv files anywhere in the workspace are binary runtime data.
# ------------------------------------------------------------------------------
.janitor/bounce_log.ndjson
.janitor/cargo_lock.hash
.janitor/diag.log
.janitor/ghost/
.janitor/heartbeat
.janitor/janitor.lic
.janitor/shadow_src/
.janitor/symbols.db
.janitor/*.rkyv
*.rkyv
!docs/v1/wisdom.rkyv


# ------------------------------------------------------------------------------
# 3. SECURITY CRITICAL — NEVER COMMIT
# Private signing keys, HSM tokens, TLS certificates, environment secrets.
# A single accidental commit of a private key invalidates the Vault entirely.
# ------------------------------------------------------------------------------
*.key
*.pem
*.pem.enc
*.pqc_secret
*.p12
*.pfx
*.token
*.seed
# Belt-and-suspenders explicit entries (also covered by *.key / *.json patterns above).
governor.key
credentials.json
secrets/
/crates/vault/secrets/
/crates/common/attestations/local/
attestations/local/
.env
.env.*
!.env.example


# ------------------------------------------------------------------------------
# 4. AI ASSISTANT INSTRUCTIONS & LOCAL OPERATIONAL DOCS
# CLAUDE.md     — internal architecture directives and AI coding-assistant config.
# RUNBOOK.md    — designer-facing operational command reference (local paths,
#                 Fly.io deployment commands, personal gauntlet targets).
# .claude/      — Claude Code project config.  Machine-local state files are
#                 ignored; project-scoped rules/commands/skills ARE committed.
# .agent/       — reserved for future agentic runtime state.
# ------------------------------------------------------------------------------
CLAUDE.md
RUNBOOK.md
.agent/
.agents/
.codex
.codex/
.cursorrules
AGENTS.md
.cursor/
.windsurf/
# Machine-local Claude Code state — never commit.
.claude/
.claude/settings.local.json
.claude/mcp.json
# Internal R&D intelligence — never push to public repo.
.INNOVATION_LOG.md


# ------------------------------------------------------------------------------
# 5. DOCUMENTATION BUILD
# `mkdocs build` and `mkdocs gh-deploy` generate the `site/` directory.
# The build output is ephemeral — only the source docs/ are tracked.
# ------------------------------------------------------------------------------
site/


# ------------------------------------------------------------------------------
# 6. PYTHON (gauntlet testing / ecosystem tooling)
# The gauntlet runs pytest against Python library repos. Python cache artifacts
# must not pollute the workspace.
# ------------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.python-version
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
.tox/
*.egg


# ------------------------------------------------------------------------------
# 7. COMPILED OBJECTS & FOREIGN BINARIES
# Object files, LLVM bitcode, and shared libraries generated during build.
# Windows executables in the repo root are NOT tracked (gh.exe lives at a
# system path on the Windows host, not in the workspace).
# Exception: the `janitor` release binary lives in target/release/ (ignored
# by rule 1 above) and is attached to GitHub Releases, not committed.
# ------------------------------------------------------------------------------
*.o
*.bc
*.so
*.dylib
*.a
*.lib
*.dll
*.exe
# jadx toolchain — download artifact, never commit
tools/jadx/lib/*.jar


# ------------------------------------------------------------------------------
# 8. IDE & EDITOR ARTIFACTS
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
\#*\#
.\#*


# ------------------------------------------------------------------------------
# 9. OPERATING SYSTEM
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/


# ------------------------------------------------------------------------------
# 10. LOGS & DIAGNOSTICS
# ------------------------------------------------------------------------------
*.log
*.log.*


# ------------------------------------------------------------------------------
# 13. DATABASES & PERSISTENT STATE FILES
# SQLite artefacts from any runtime component (Governor, legacy janitor state).
# ------------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal


# ------------------------------------------------------------------------------
# 14. SOCKETS & IPC
# Unix domain sockets created by `janitor serve` and the Governor daemon.
# These are ephemeral; they must never be committed.
# ------------------------------------------------------------------------------
*.sock


# ------------------------------------------------------------------------------
# 15. GOVERNOR / THE JANITOR RUNTIME ARTEFACTS
# /bonds/         — Governor bond state written at runtime.
# /integrity.jsonl — append-only integrity log (runtime, not source).
# Neither belongs in source control.
# ------------------------------------------------------------------------------
/bonds/
/integrity.jsonl


# ------------------------------------------------------------------------------
# 11. TREE-SITTER / C GRAMMAR GENERATED FILES
# The `cc` crate compiles tree-sitter grammar `.c` sources at build time.
# Any `parser.c` in the workspace is generated, not authored.
# ------------------------------------------------------------------------------
parser.c


# ------------------------------------------------------------------------------
# 12. NODE.JS (optional tooling, not a primary dependency)
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/
package-lock.json
*.deb


# ------------------------------------------------------------------------------
# 16. REPORTING & MEDIA ARTIFACTS
# Runtime-generated reports, exports, and media must never enter version control.
# Use docs/assets/ for intentionally tracked marketing/demo assets (whitelisted
# below). All other CSV/PDF/MP4/patch/ndjson files in any directory are ignored.
# ------------------------------------------------------------------------------
*.csv
*.pdf
*.mp4
*.patch
*.diff
*.ndjson
# Root-level JSON and TXT scan artifacts (runtime output, not source)
/*.json
# Exception: MCP discovery manifest is a committed source artifact
!mcp-manifest.json
/*.txt
# Gauntlet target lists (operator-local, not committed — base + variants)
gauntlet_targets.txt
gauntlet_targets_*.txt
# Forensic strike output packages (just strike → strikes/<repo>/)
strikes/
# Gauntlet test harness output
janitor-test-gauntlet/

# Whitelist: official docs assets are intentionally tracked.
!docs/assets/*.pdf
!docs/assets/*.csv
!docs/assets/*.mp4
!docs/assets/*.webp
